# Required API Keys
BRAVE_API_KEY=your_brave_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: YouTube Data API key
# Enables resolving /@handle channel URLs to actual videos.
# /channel/ID URLs are resolved via RSS and don't need this key.
# Get one free at console.cloud.google.com (10,000 quota units/day)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Port (Railway sets this automatically)
PORT=8000
